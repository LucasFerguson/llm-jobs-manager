REDIS_PASSWORD=your_redis_password_here
LITELLM_BASE_URL=http://<url>:4000
LITELLM_API_KEY=sk-your-key-if-you-enabled-proxy-auth

# Hierarchy summarization defaults (optional overrides for CLI)
NOTE_SENTENCES=2
FOLDER_SENTENCES=3
ROOT_SENTENCES=5

# Agent API
OBSIDIAN_VAULT_PATH=./input
AGENT_DB_PATH=./agent.db
AGENT_PORT=3334

# OpenAI-compatible gateway (point Open WebUI's API Base URL here)
GATEWAY_PORT=3335
GATEWAY_TIMEOUT_MS=300000
